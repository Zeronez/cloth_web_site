# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=0
SECRET_KEY=
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=

# Postgres
POSTGRES_DB=animeattire
POSTGRES_USER=animeattire
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME_DAYS=14
SIMPLE_JWT_ROTATE_REFRESH_TOKENS=1
SIMPLE_JWT_BLACKLIST_AFTER_ROTATION=1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=AnimeAttire <no-reply@example.com>
SERVER_EMAIL=AnimeAttire <no-reply@example.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10

# S3 / compatible object storage
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1

# Payment webhooks
PAYMENT_WEBHOOK_BYPASS_PROVIDERS=manual,placeholder,local
PAYMENT_WEBHOOK_SECRETS_JSON={}
PAYMENT_WEBHOOK_SIGNATURE_HEADERS_JSON={}
PAYMENT_PROVIDER_CONFIRMATION_URLS_JSON={"yookassa":"https://yookassa.example/checkout"}
PAYMENT_PROVIDER_RETURN_BASE_URL=http://localhost:3000/checkout/return

# App ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
