DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=0

APP_DOMAIN=animeattire.ru
ACME_EMAIL=ops@animeattire.ru

POSTGRES_DB=animeattire
POSTGRES_USER=animeattire
POSTGRES_PASSWORD=replace-with-long-db-password

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SECRET_KEY=replace-with-64-plus-character-django-secret-key
ALLOWED_HOSTS=animeattire.ru,www.animeattire.ru
CSRF_TRUSTED_ORIGINS=https://animeattire.ru,https://www.animeattire.ru
CORS_ALLOWED_ORIGINS=https://animeattire.ru,https://www.animeattire.ru

DEFAULT_FROM_EMAIL=AnimeAttire <no-reply@animeattire.ru>
SERVER_EMAIL=AnimeAttire <ops@animeattire.ru>
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.example
EMAIL_PORT=587
EMAIL_HOST_USER=mailer
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
AUTH_EMAIL_CONFIRMATION_PATH=/auth/confirm-email
AUTH_PASSWORD_RESET_PATH=/auth/reset-password

PRIVACY_POLICY_VERSION=2026-05
OFFER_AGREEMENT_VERSION=2026-05
MARKETING_CONSENT_VERSION=2026-05

AVATAR_UPLOAD_MAX_BYTES=2097152
PRODUCT_IMAGE_UPLOAD_MAX_BYTES=8388608
IMAGE_UPLOAD_MAX_PIXELS=16000000

CONTENT_SECURITY_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'
CONTENT_SECURITY_POLICY_REPORT_ONLY=0

AUTH_LOGIN_FAILURE_WINDOW_SECONDS=900
AUTH_LOGIN_FAILURE_IP_LIMIT=5
AUTH_LOGIN_FAILURE_ACCOUNT_LIMIT=10
AUTH_PASSWORD_RESET_REQUEST_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_REQUEST_LIMIT=3
AUTH_PASSWORD_RESET_CONFIRM_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_CONFIRM_LIMIT=5

SIMPLE_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME_DAYS=14
SIMPLE_JWT_ROTATE_REFRESH_TOKENS=1
SIMPLE_JWT_BLACKLIST_AFTER_ROTATION=1

PAYMENT_WEBHOOK_BYPASS_PROVIDERS=
PAYMENT_WEBHOOK_SECRETS_JSON={"yookassa":"replace-with-provider-webhook-secret-of-32-plus-characters"}
PAYMENT_WEBHOOK_SIGNATURE_HEADERS_JSON={}
PAYMENT_PROVIDER_CONFIRMATION_URLS_JSON={"yookassa":"https://checkout.animeattire.ru/yookassa"}
PAYMENT_PROVIDER_STATUS_OVERRIDES_JSON={}

DELIVERY_METHOD_AVAILABILITY_OVERRIDES_JSON={}
DELIVERY_PROVIDER_TRACKING_OVERRIDES_JSON={}
DELIVERY_PICKUP_POINT_OVERRIDES_JSON={}

PAYMENT_SESSION_TIMEOUT_MINUTES=20
PAYMENT_EXPIRATION_BATCH_SIZE=100
CART_GUEST_TTL_HOURS=72
CART_CLEANUP_BATCH_SIZE=200

CELERY_TASK_DEFAULT_QUEUE=default
CELERY_NOTIFICATION_QUEUE=notifications
CELERY_TASK_TIME_LIMIT=300
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_NOTIFICATION_MAX_RETRIES=3
CELERY_NOTIFICATION_RETRY_BACKOFF_SECONDS=30
CELERY_NOTIFICATION_RETRY_MAX_SECONDS=300
CELERY_NOTIFICATION_PROCESSING_LEASE_SECONDS=600

HEALTH_CHECK_CELERY_ENABLED=1
HEALTH_CHECK_CELERY_RESULT_BACKEND_ENABLED=1
HEALTH_CHECK_CELERY_WORKERS_ENABLED=0
HEALTH_CHECK_CELERY_MIN_WORKERS=1

AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=eu-central-1

NEXT_PUBLIC_API_PREFIX=/api/v1
