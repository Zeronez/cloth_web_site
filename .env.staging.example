DJANGO_SETTINGS_MODULE=config.settings.staging
DEBUG=0

POSTGRES_DB=animeattire_staging
POSTGRES_USER=animeattire
POSTGRES_PASSWORD=animeattire-staging
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SECRET_KEY=animeattire-staging-secret-key-change-me-please
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001
STAGING_PUBLIC_BASE_URL=http://localhost:3001
STAGING_RESTORE_DRILL_ENABLED=0
STAGING_MEDIA_BUCKET=animeattire-staging-media
STAGING_MEDIA_BACKUP_PREFIX=backups/media
STAGING_DATABASE_BACKUP_PREFIX=backups/postgres
STAGING_RESTORE_MAX_AGE_HOURS=72

AWS_STORAGE_BUCKET_NAME=animeattire-staging-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION_NAME=us-east-1

DEFAULT_FROM_EMAIL=AnimeAttire Staging <no-reply@example.com>
SERVER_EMAIL=AnimeAttire Staging <no-reply@example.com>
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

PAYMENT_PROVIDER_RETURN_BASE_URL=http://localhost:3001/checkout/return
PAYMENT_PROVIDER_CONFIRMATION_URLS_JSON={"yookassa":"https://checkout.example.com/yookassa"}
PAYMENT_WEBHOOK_SECRETS_JSON={"yookassa":"staging-webhook-secret-with-at-least-32-chars"}
PAYMENT_WEBHOOK_BYPASS_PROVIDERS=
PAYMENT_WEBHOOK_SIGNATURE_HEADERS_JSON={}
PAYMENT_PROVIDER_STATUS_OVERRIDES_JSON={}
DELIVERY_METHOD_AVAILABILITY_OVERRIDES_JSON={}
DELIVERY_PROVIDER_TRACKING_OVERRIDES_JSON={}
DELIVERY_PICKUP_POINT_OVERRIDES_JSON={}

NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_API_PREFIX=/api/v1
STAGING_BACKEND_PORT=8001
STAGING_FRONTEND_PORT=3001
STAGING_POSTGRES_PORT=5434
STAGING_REDIS_PORT=6380
STAGING_MINIO_PORT=9000
STAGING_MINIO_CONSOLE_PORT=9001
